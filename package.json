{
  "name": "alumni-management-portal-v2",
  "version": "2.0.0",
  "description": "An enterprise-grade, glassmorphic full-stack ecosystem engineered for role-based academic networking, mentorship, and career growth.",
  "main": "index.html",
  "scripts": {
    "start:frontend": "npx serve . -p 3000",
    "start:backend": "cd backend && python manage.py runserver",
    "setup:backend": "cd backend && python -m venv venv && pip install -r requirements.txt",
    "db:migrate": "cd backend && python manage.py makemigrations && python manage.py migrate",
    "db:admin": "cd backend && python manage.py createsuperuser",
    "dev": "echo \"Please run 'npm run start:frontend' and 'npm run start:backend' in separate terminals.\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kulkarnishub377/Alumni_Management_portal.git"
  },
